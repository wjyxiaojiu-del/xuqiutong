# 数据库（PostgreSQL，必填）
DATABASE_URL="postgresql://user:password@localhost:5432/xuqiutong"

# AI Provider（填写任意一个即可，多个会自动 fallback）
# DeepSeek（推荐，中文效果好，便宜）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Mock 模式（设为 true 时强制使用 Mock，忽略上面的 Key）
ENABLE_MOCK_AI="true"

# Seed 接口密钥（设置后 /api/seed 需要 x-seed-secret header）
SEED_SECRET=""
